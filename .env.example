# Example environment variables for YDAuto / YDA Cleaning
# Copy this to .env and fill values before running docker-compose or deploying

# Django
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database (Postgres example)
# You can also set a DATABASE_URL instead (e.g. postgres://user:pass@host:5432/dbname)
POSTGRES_DB=ydauto
POSTGRES_USER=ydauto
POSTGRES_PASSWORD=ydautopass

# Email / SendGrid
SENDGRID_API_KEY=
DJANGO_DEFAULT_FROM=no-reply@yourdomain.com

# Optional SMTP fallback
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# Render deploy (if using Render)
RENDER_SERVICE_ID=
RENDER_API_KEY=
